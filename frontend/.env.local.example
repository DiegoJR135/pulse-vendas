# .env.local.example
# Copie para .env.local e ajuste conforme o ambiente.

# URL do backend Python (FastAPI) — só é usada quando o simulador está desligado.
NEXT_PUBLIC_API_URL=http://localhost:8000

# "true" (padrão) = usa dados fake gerados no navegador, sem precisar do backend rodando.
# "false" = conecta de verdade via SSE em NEXT_PUBLIC_API_URL/api/dashboard/stream.
NEXT_PUBLIC_USE_SIMULATOR=true
